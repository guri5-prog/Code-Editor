{
  "name": "code-editor",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight, education-focused, web-based code editor",
  "workspaces": [
    "packages/shared",
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev -w packages/client\" \"npm run dev -w packages/server\"",
    "build": "npm run build -w packages/shared && npm run build -w packages/client && npm run build -w packages/server",
    "test": "npm run test -w packages/server",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -b packages/shared packages/client packages/server",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,css}\"",
    "prepare": "node -e \"if (process.env.CI || process.env.NODE_ENV === 'production') process.exit(0)\" && husky"
  },
  "engines": {
    "node": ">=18.0.0"
